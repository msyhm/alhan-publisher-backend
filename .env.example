# ─────────────────────────────────────────────────────────────────────────
# .env.example — انتشارات الحان (بکند)
# این فایل را کپی کنید به .env و مقادیر واقعی را پر کنید
# هرگز فایل .env واقعی را در گیت commit نکنید!
# ─────────────────────────────────────────────────────────────────────────

# ─── سرور ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# آدرس فرانت‌اند — برای تنظیم CORS
FRONTEND_URL=http://localhost:5173

# ─── دیتابیس (PostgreSQL) ──────────────────────────────────────────────
# فرمت: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/alhan_publisher?schema=public"

# ─── احراز هویت ──────────────────────────────────────────────────────────
# یک رشته تصادفی طولانی و امن بسازید (مثلاً: openssl rand -base64 32)
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# اطلاعات اولیه ادمین — فقط برای seed اولیه دیتابیس استفاده می‌شود
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-this-password

# ─── آپلود فایل ──────────────────────────────────────────────────────────
# مسیر ذخیره فایل‌های آپلودشده (تصاویر کتاب، فایل آثار ارسالی)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── Rate Limiting ───────────────────────────────────────────────────────
# جلوگیری از spam روی فرم تماس و تلاش‌های لاگین
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
